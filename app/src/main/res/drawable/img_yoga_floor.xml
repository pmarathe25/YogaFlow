        android:fillColor="#E07A5F"
        android:pathData="M80,118 m-9,0 a9,9 0,1,1 18,0 a9,9 0,1,1 -18,0" />
    
    <!-- Torso sitting or folded softly -->
    <path
        android:fillColor="#E07A5F"
        android:pathData="M80,128 C86,128 100,132 100,145 L100,160 L75,160 C70,160 68,155 68,150 L68,140 Z" />
    
    <!-- Arms resting on knees or floor -->
    <path
        android:strokeColor="#E07A5F"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M80,135 C90,140 110,145 115,160" />

    <!-- Legs folded or tucked underneath -->
